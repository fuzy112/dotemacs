#!/usr/bin/env bash

set -euo pipefail

SOURCE_DIR="$(realpath "$(dirname "$0")")"
PATH=${PATH//"$SOURCE_DIR:"//}

declare -a args
unset "args[@]"

provider=deepseek

for arg in "$@"; do
    case "$arg" in
        --deepseek)
            provider=deepseek
            ;;
        --kimi|--moonshot)
            provider=moonshot
            ;;
        --kimi-coding)
            provider=kimi-coding
            ;;
        *)
            args+=("$arg")
            ;;
    esac
done

case "$provider" in
    deepseek)
        export ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
        ANTHROPIC_API_KEY="$(secret-tool lookup host api.deepseek.com)"
        export ANTHROPIC_API_KEY
        export ANTHROPIC_MODEL=deepseek-chat
        export ANTHROPIC_SMALL_FAST_MODEL=deepseek-chat
        ;;
    moonshot)
        export ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
        ANTHROPIC_API_KEY="$(secret-tool lookup host api.moonshot.cn)"
        export ANTHROPIC_API_KEY
        export ANTHROPIC_MODEL=kimi-k2-turbo-preview
        export ANTHROPIC_SMALL_FAST_MODEL=kimi-k2-turbo-preview
        ;;
    kimi-coding)
        export ENABLE_TOOL_SEARCH=false
        export ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
        ANTHROPIC_API_KEY=$(pass api.kimi.com | head -1)
        export ANTHROPIC_API_KEY
        ;;
esac

CLAUDE_CODE_CLI=
if command -v claude >/dev/null; then
    CLAUDE_CODE_CLI=claude
elif command -v nix >/dev/null; then
    # Use nix shell to run claude if nix is available
    export NIXPKGS_ALLOW_UNFREE=1
    CLAUDE_CODE_CLI="nix run nixpkgs#claude-code --"
else
    CLAUDE_CODE_CLI="npm exec --package=@anthropic-ai/claude-code@latest claude --"
fi

exec $CLAUDE_CODE_CLI "${args[@]}"
